# Server Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (REQUIRED)
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>
MONGODB_URI=mongodb://localhost:27017/toptier

# JWT Configuration (REQUIRED for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP Email Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin User (for initial seeding - optional)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@toptier.com
ADMIN_PASSWORD=SecurePassword123!
